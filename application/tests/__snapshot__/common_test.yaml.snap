      name: application-certificate
      namespace: NAMESPACE
    spec:
      commonName: admin-app
      duration: 8760h0m0s
      issuerRef:
        kind: ClusterIssuer
        name: ca-issuer
      keystores:
        pkcs12:
          create: true
          passwordSecretRef:
            key: test_key
            name: test-creds
      privateKey:
        algorithm: RSA
        encoding: PKCS1
        rotationPolicy: Always
        size: 2048
      renewBefore: 720h0m0s
      secretName: tls-cert
