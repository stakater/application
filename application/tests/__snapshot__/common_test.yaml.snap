  21: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      annotations:
        ingress.kubernetes.io/force-ssl-redirect: "true"
        ingress.kubernetes.io/rewrite-target: /
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        key: value
        team: stakater
      name: application
      namespace: NAMESPACE
    spec:
      ingressClassName: nginx
      rules:
        - host: chart-example.local
          http:
            paths:
              - backend:
                  service:
                    name: application
                    port:
                      name: http
                path: /
                pathType: ImplementationSpecific
              - backend:
                  service:
                    name: application
                    port:
                      name: http
                path: /subpath
                pathType: ImplementationSpecific
        - host: RELEASE-NAME.stakater.com
          http:
            paths:
              - backend:
                  service:
                    name: application
                    port:
                      name: http
                path: /
                pathType: ImplementationSpecific
      tls:
        - hosts:
            - chart-example.local
            - RELEASE-NAME.stakater.com
          secretName: chart-example-tls
  22: |
    apiVersion: batch/v1beta1
    kind: Job
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        team: stakater
      name: application-db-migration
      namespace: NAMESPACE
    spec:
      template:
        metadata:
          annotations:
            helm.sh/hook: pre-install,pre-upgrade
            helm.sh/hook-delete-policy: before-hook-creation
            helm.sh/hook-weight: "-1"
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: application
            app.kubernetes.io/version: example-tag
            application.stakater.com/workload-class: batch
            group: com.stakater.platform
            helm.sh/chart: application-8.0.0
            team: stakater
        spec:
          automountServiceAccountToken: false
          containers:
            - args:
                - -c
                - sleep 5000
              command:
                - /bin/bash
              env:
                - name: KEY
                  value: VALUE
              envFrom:
                - configMapRef:
                    name: my-existing-configmap
                    optional: false
                - secretRef:
                    name: my-existing-secret
                    optional: false
              image: registry/example-image:example-tag@sha256:example-digest
              name: db-migration
              resources:
                limits:
                  cpu: 500m
                  memory: 512Mi
                requests:
                  cpu: 100m
                  memory: 256Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 65534
                seccompProfile:
                  type: RuntimeDefault
          dnsConfig:
            options:
              - name: ndots
                value: "1"
          imagePullSecrets:
            - name: nexus-secret
          restartPolicy: OnFailure
          securityContext:
            runAsNonRoot: true
            runAsUser: 65534
            seccompProfile:
              type: RuntimeDefault
          serviceAccountName: application
  23: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
