    spec:
      egress:
        - ports:
            - port: 5978
              protocol: TCP
          to:
            - ipBlock:
                cidr: 10.0.0.0/24
      ingress:
        - from:
            - ipBlock:
                cidr: 172.17.0.0/16
                except:
                  - 172.17.1.0/24
            - namespaceSelector:
                matchLabels:
                  project: myproject
            - podSelector:
                matchLabels:
                  role: frontend
          ports:
            - port: 6379
              protocol: TCP
      podSelector:
        matchLabels:
          app.kubernetes.io/name: application
          application.stakater.com/workload-class: serving
          env: prod
      policyTypes:
        - Ingress
        - Egress
