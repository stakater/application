  10: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        team: stakater
      name: application-db-migration
      namespace: NAMESPACE
    spec:
      jobTemplate:
        spec:
          template:
            metadata:
              labels:
                app.kubernetes.io/instance: RELEASE-NAME
                app.kubernetes.io/managed-by: Helm
                app.kubernetes.io/name: application
                app.kubernetes.io/version: example-tag
                application.stakater.com/workload-class: scheduled
                group: com.stakater.platform
                helm.sh/chart: application-8.0.0
                team: stakater
            spec:
              automountServiceAccountToken: false
              containers:
                - args:
                    - -c
                    - sleep 5000
                  command:
                    - /bin/bash
                  env:
                    - name: KEY
                      value: VALUE
                  envFrom:
                    - configMapRef:
                        name: my-existing-configmap
                        optional: false
                    - secretRef:
                        name: my-existing-secret
                        optional: false
                  image: registry/example-image:example-tag
                  name: db-migration
                  resources:
                    limits:
                      cpu: 500m
                      memory: 512Mi
                    requests:
                      cpu: 100m
                      memory: 256Mi
                  securityContext:
                    allowPrivilegeEscalation: false
                    capabilities:
                      drop:
                        - ALL
                    readOnlyRootFilesystem: true
                    runAsNonRoot: true
                    runAsUser: 65534
                    seccompProfile:
                      type: RuntimeDefault
              dnsConfig:
                options:
                  - name: ndots
                    value: "1"
              imagePullSecrets:
                - name: nexus-secret
              priorityClassName: high-priority
              restartPolicy: OnFailure
              securityContext:
                runAsNonRoot: true
                runAsUser: 65534
                seccompProfile:
                  type: RuntimeDefault
              serviceAccountName: application
      schedule: '* * * 8 *'
  11: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      annotations:
        reloader.stakater.com/auto: "true"
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        key: value
        team: stakater
      name: application
      namespace: NAMESPACE
    spec:
      replicas: 2
      revisionHistoryLimit: 2
      selector:
        matchLabels:
          app.kubernetes.io/name: application
          application.stakater.com/workload-class: serving
      strategy:
        rollingUpdate:
          maxSurge: 25%
          maxUnavailable: 25%
        type: RollingUpdate
      template:
        metadata:
          annotations:
            fluentdConfiguration: |
              [
                {
                  "containers":
                  [
                    {
                      "expressionFirstLine": "",
                      "expression": "",
                      "timeFormat": "",
                      "containerName": "application"
                    }
                  ]
                }
              ]
            key: value
          labels:
            app.kubernetes.io/instance: RELEASE-NAME
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: application
            app.kubernetes.io/version: example-tag
            application.stakater.com/workload-class: serving
            env: prod
            group: com.stakater.platform
            helm.sh/chart: application-8.0.0
            team: stakater
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: disktype
                        operator: In
                        values:
                          - ssd
          automountServiceAccountToken: false
          containers:
            - args:
                - --https-address=:8443
                - --provider=openshift
                - --upstream=http://localhost:8080
                - --openshift-service-account=application
                - --tls-cert=/etc/tls/private/tls.crt
                - --tls-key=/etc/tls/private/tls.key
                - --cookie-secret=SECRET
              image: openshift/oauth-proxy:latest
              imagePullPolicy: IfNotPresent
              name: oauth-proxy
              ports:
                - containerPort: 8443
                  name: proxy
              volumeMounts:
                - mountPath: /etc/tls/private
                  name: proxy-tls
            - env:
                - name: ENVIRONMENT
                  value: dev
              envFrom:
                - configMapRef:
                    name: my-existing-configmap
                    optional: false
                - secretRef:
                    name: my-existing-secret
                    optional: false
                - secretRef:
                    name: application-nonexisting
                    optional: true
                - secretRef:
                    name: application-postgres
                    optional: false
                - configMapRef:
                    name: application-my-configmap
                    optional: false
              image: registry/example-image:example-tag
              imagePullPolicy: IfNotPresent
              lifecycle:
                preStop:
                  exec:
                    command:
                      - /bin/sh
                      - -c
                      - sleep 20
              livenessProbe:
                failureThreshold: 3
                httpGet:
                  path: /path
                  port: 8080
                initialDelaySeconds: 10
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 1
              name: application
              ports:
                - containerPort: 8080
                  name: http
                  protocol: TCP
                - containerPort: 8778
                  name: jolokia
                  protocol: TCP
                - containerPort: 8443
                  name: https
                  protocol: TCP
              readinessProbe:
                exec:
                  command:
                    - cat
                    - tmp/healthy
                failureThreshold: 3
                initialDelaySeconds: 10
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 1
              resources:
                limits:
                  cpu: 0.5
                  memory: 256Mi
                requests:
                  cpu: 0.1
                  memory: 128Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 65534
                seccompProfile:
                  type: RuntimeDefault
              startupProbe:
                failureThreshold: 30
                httpGet:
                  path: /path
                  port: 8080
                periodSeconds: 10
                successThreshold: 1
                timeoutSeconds: 1
              volumeMounts:
                - mountPath: /path1
                  name: volume-name
            - command:
                - /bin/sh
                - -c
                - sleep 3600
              image: registry/example-image:example-tag
              imagePullPolicy: IfNotPresent
              livenessProbe:
                exec:
                  command:
                    - "true"
              name: sidecar-container
              readinessProbe:
                exec:
                  command:
                    - "true"
              resources:
                limits:
                  cpu: 50m
                  memory: 32Mi
                requests:
                  cpu: 10m
                  memory: 16Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 65534
                seccompProfile:
                  type: RuntimeDefault
          dnsConfig:
            options:
              - name: ndots
                value: "1"
          dnsPolicy: ClusterFirst
          enableServiceLinks: true
          hostAliases:
            - hostnames:
                - foo.local
                - bar.local
              ip: 127.0.0.1
            - hostnames:
                - foo.remote
                - bar.remote
              ip: 10.1.2.3
          hostNetwork: true
          initContainers:
            - command:
                - /bin/sh
              image: registry/example-image:example-tag
              imagePullPolicy: IfNotPresent
              name: init-container
              resources:
                limits:
                  cpu: 50m
                  memory: 32Mi
                requests:
                  cpu: 10m
                  memory: 16Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                readOnlyRootFilesystem: true
                runAsNonRoot: true
                runAsUser: 65534
                seccompProfile:
                  type: RuntimeDefault
          securityContext:
            runAsNonRoot: true
            runAsUser: 65534
            seccompProfile:
              type: RuntimeDefault
          serviceAccountName: application
          terminationGracePeriodSeconds: 120
          tolerations:
            - effect: NoSchedule
              key: dedicated
              operator: Equal
              value: app
          volumes:
            - name: proxy-tls
              secret:
                secretName: openshift-oauth-proxy-tls
            - configMap:
                name: configmap-name
              name: config-volume
            - configMap:
                name: application-configmap-nameSuffix
              name: configmap-volume
            - name: persistent-volume-name
              persistentVolumeClaim:
                claimName: claim-name
            - name: secret-volume
              secret:
                secretName: secret-name
            - emptyDir: {}
              name: volume-name
