should match snapshot:
  1: |
    apiVersion: monitoring.coreos.com/v1alpha1
    kind: AlertmanagerConfig
    metadata:
      labels:
        alertmanagerConfig: workload
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        team: stakater
      name: application
      namespace: NAMESPACE
    spec:
      inhibitRules:
        - equal:
            - cluster
            - service
          sourceMatch:
            - name: severity
              value: critical
          targetMatch:
            - name: severity
              value: warning
      receivers:
        - name: "null"
      route:
        groupBy:
          - job
        groupInterval: 5m
        groupWait: 30s
        receiver: "null"
        repeatInterval: 12h
        routes:
          - continue: true
            groupBy:
              - alertname
              - severity
            receiver: "null"
  2: |
    apiVersion: velero.io/v1
    kind: Backup
    metadata:
      labels:
        app.kubernetes.io/instance: RELEASE-NAME
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: application
        app.kubernetes.io/version: example-tag
        group: com.stakater.platform
        helm.sh/chart: application-8.0.0
        team: stakater
      name: application-backup
      namespace: openshift-adp
    spec:
      defaultVolumesToRestic: true
      excludedResources:
        - daemonsets
        - statefulsets
        - nodes
        - apiservices
        - events
        - resourcequotas
        - controllerrevisions.apps
      includedNamespaces:
        - NAMESPACE
      includedResources:
        - deployments
        - services
        - persistentvolumeclaims
        - secrets
        - configmaps
      labelSelector:
        matchLabels:
          app.kubernetes.io/part-of: application
      snapshotVolumes: true
      storageLocation: dpa-1
      ttl: 1h0m0s
